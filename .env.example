# Admin credentials (static — no database)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Manager credentials (same access as admin, except settings)
MANAGER_USERNAME=manager
MANAGER_PASSWORD=change-me-in-production

# JWT signing secret (generate: openssl rand -base64 32)
ADMIN_JWT_SECRET=change-me-in-production

# iron-session cookie encryption (generate: openssl rand -base64 32, must be >= 32 chars)
IRON_SESSION_PASSWORD=change-me-in-production

# Vercel Blob (production only — leave empty in dev)
BLOB_READ_WRITE_TOKEN=

# Gemini API (auto-translation in question editor)
GEMINI_API_KEY=

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
